---

<BlogLayout title="Enlaces Útiles - DevIA Blog" description="Colección curada de enlaces y recursos útiles para programadores y desarrolladores de IA">
	<div class="page-header">
		<h1 class="page-title">Enlaces Útiles</h1>
		<p class="page-subtitle">
			Una colección curada de recursos, herramientas y plataformas esenciales para desarrolladores.
			Desde APIs de IA hasta frameworks de desarrollo web.
		</p>
	</div>

	<div class="links-container">
		{linkCategories.map((category) => (
			<section class="category-section">
				<div class="category-header">
					<div class="category-icon">{category.icon}</div>
					<div class="category-info">
						<h2 class="category-title">{category.category}</h2>
						<p class="category-description">{category.description}</p>
					</div>
				</div>
				
				<div class="links-grid">
					{category.links.map((link) => (
						<a href={link.url} class="link-card" target="_blank" rel="noopener noreferrer">
							<div class="link-icon">{link.icon ?? ''}</div>
							<div class="link-content">
								<div class="link-header">
									<h3 class="link-title">{link.title}</h3>
									<span class="link-type">{link.type}</span>
								</div>
								<p class="link-description">{link.description}</p>
								<div class="link-url">{link.url}</div>
							</div>
							<div class="link-arrow">→</div>
						</a>
					))}
				</div>
			</section>
		))}
	</div>

</BlogLayout>

<style>
	.page-header {
		text-align: center;
		margin-bottom: 64px;
	}

	.page-title {
		font-family: var(--font-mono);
		font-size: 42px;
		font-weight: 700;
		color: var(--text);
		margin-bottom: 16px;
		letter-spacing: -1px;
	}

	.page-subtitle {
		font-size: 20px;
		color: var(--text-muted);
		line-height: 1.6;
		max-width: 800px;
		margin: 0 auto;
	}

	.links-container {
		display: flex;
		flex-direction: column;
		gap: 64px;
		margin-bottom: 80px;
	}

	.category-section {
		margin-bottom: 64px;
	}

	.category-header {
		display: flex;
		align-items: center;
		gap: 16px;
		margin-bottom: 24px;
	}

	.category-icon {
		font-size: 28px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.category-title {
		font-family: var(--font-mono);
		font-size: 24px;
		font-weight: 600;
		color: var(--text);
		margin-bottom: 4px;
	}

	.category-description {
		font-size: 15px;
		color: var(--text-muted);
		line-height: 1.5;
		margin: 0;
	}

	.links-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
		gap: 24px;
	}

	.link-card {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 20px;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 12px;
		text-decoration: none;
		transition: all 0.3s var(--ease);
	}

	.link-icon {
		flex: 0 0 48px;
		height: 48px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 24px;
		background: var(--bg-soft);
		border: 1px solid var(--border);
		border-radius: 10px;
		margin-right: 16px;
	}

	.link-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 25px rgba(0,0,0,0.3);
		border-color: var(--accent);
	}

	.link-content {
		flex: 1;
	}

	.link-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 8px;
	}

	.link-title {
		font-size: 18px;
		font-weight: 600;
		color: var(--text);
		margin: 0;
	}

	.link-type {
		background: var(--accent-soft);
		color: var(--accent);
		padding: 4px 8px;
		border-radius: 6px;
		font-size: 12px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}

	.link-description {
		color: var(--text-muted);
		font-size: 14px;
		line-height: 1.5;
		margin: 0 0 8px 0;
	}

	.link-url {
		color: var(--text-dim);
		font-size: 12px;
		font-family: var(--font-mono);
	}

	.link-arrow {
		font-size: 20px;
		color: var(--text-dim);
		transition: all 0.3s var(--ease);
		margin-left: 16px;
	}

	.link-card:hover .link-arrow {
		color: var(--accent);
		transform: translateX(4px);
	}

	.suggest-section {
		margin-bottom: 80px;
	}

	.suggest-card {
		background: linear-gradient(135deg, var(--amber), oklch(0.7 0.18 75));
		border-radius: 20px;
		padding: 48px;
		text-align: center;
		color: var(--bg);
	}

	.suggest-title {
		font-size: 32px;
		font-weight: 700;
		margin-bottom: 16px;
	}

	.suggest-description {
		font-size: 18px;
		line-height: 1.6;
		margin-bottom: 32px;
		opacity: 0.9;
		max-width: 600px;
		margin-left: auto;
		margin-right: auto;
	}

	.suggest-btn {
		display: inline-block;
		background: var(--bg);
		color: var(--amber);
		text-decoration: none;
		padding: 16px 32px;
		border-radius: 12px;
		font-weight: 700;
		font-size: 16px;
		transition: all 0.3s var(--ease);
	}

	.suggest-btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 15px rgba(0, 0, 0, 0.2);
	}

	@media (max-width: 768px) {
		.page-title {
			font-size: 36px;
		}

		.page-subtitle {
			font-size: 18px;
		}

		.category-section {
			padding: 32px 24px;
		}

		.category-header {
			flex-direction: column;
			text-align: center;
			gap: 16px;
		}

		.category-icon {
			width: 60px;
			height: 60px;
			font-size: 32px;
		}

		.category-title {
			font-size: 24px;
		}

		.links-grid {
			grid-template-columns: 1fr;
		}

		.link-card {
			padding: 20px;
		}

		.link-header {
			flex-direction: column;
			align-items: flex-start;
			gap: 8px;
		}

		.suggest-card {
			padding: 32px 24px;
		}

		.suggest-title {
			font-size: 24px;
		}

		.suggest-description {
			font-size: 16px;
		}
	}
</style>