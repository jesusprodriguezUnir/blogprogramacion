---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { normalizeBase } from '../../utils/url';
import { skillCategories, skillSlug } from '../../data/skills';

const rawBase = (import.meta as any).env.BASE_URL as string | undefined;
const base = normalizeBase(rawBase);

export async function getStaticPaths() {
  const paths = [];

  for (const category of skillCategories) {
    for (const prompt of category.prompts) {
      paths.push({
        params: { slug: skillSlug(prompt.title) },
        props: { prompt, category: category.category, categoryIcon: category.icon }
      });
    }
  }

  return paths;
}

const { prompt, category, categoryIcon } = Astro.props;

const skillContent = `TITULO: ${prompt.title}
CATEGORIA: ${category}
TAGS: ${prompt.tags.join(', ')}

---

PROMPT:
${prompt.prompt}`;
---

<BlogLayout title={`Skill: ${prompt.title}`} description={`Skill de ${category} - ${prompt.title}`}>
  <article class="skill-detail">
    <a href={`${base}/prompts`} class="back-link mono">← cd ../skills</a>

    <header class="skill-header glass">
      <span class="category-badge mono">{categoryIcon} {category}</span>
      <h1 class="skill-title">{prompt.title}</h1>
      <div class="tags">
        {prompt.tags.map((tag: string) => (
          <span class="tag mono">{tag}</span>
        ))}
      </div>
    </header>

    <section class="skill-content glass">
      <h2 class="mono">Prompt</h2>
      <div class="prompt-box">{prompt.prompt}</div>

      <button id="downloadBtn" class="download-btn mono" data-content={skillContent} data-filename={`skill-${skillSlug(prompt.title)}.txt`}>
        download_skill --txt
      </button>
    </section>
  </article>
</BlogLayout>

<script>
  const downloadBtn = document.getElementById('downloadBtn');
  if (downloadBtn) {
    downloadBtn.addEventListener('click', () => {
      const content = downloadBtn.getAttribute('data-content') || '';
      const filename = downloadBtn.getAttribute('data-filename') || 'skill.txt';
      const blob = new Blob([content], { type: 'text/plain;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    });
  }
</script>

<style>
  .skill-detail {
    max-width: 850px;
    margin: 0 auto;
    padding-top: 1rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    color: var(--text-dim);
    margin-bottom: 1.5rem;
    transition: all 0.3s var(--ease);
  }

  .back-link:hover {
    color: var(--accent);
    transform: translateX(-4px);
  }

  .skill-header {
    border: 1px solid var(--border);
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .category-badge {
    display: inline-block;
    background: var(--accent-soft);
    color: var(--accent);
    padding: 0.35rem 0.75rem;
    border-radius: 8px;
    font-size: 0.72rem;
    margin-bottom: 1rem;
    border: 1px solid var(--border);
  }

  .skill-title {
    font-size: 2rem;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    background: var(--bg-soft);
    color: var(--accent);
    padding: 0.25rem 0.55rem;
    border-radius: 6px;
    font-size: 0.72rem;
    border: 1px solid var(--border);
  }

  .skill-content {
    border: 1px solid var(--border);
    padding: 1.5rem;
  }

  .prompt-box {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin: 1rem 0 1.5rem;
    white-space: pre-wrap;
  }

  .download-btn {
    background: var(--accent-soft);
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 0.8rem 1.2rem;
    border-radius: 10px;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.3s var(--ease);
  }

  .download-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px var(--accent-soft);
    background: var(--accent-glow);
    color: var(--bg);
  }

  .download-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .skill-title {
      font-size: 1.5rem;
    }

    .skill-header,
    .skill-content {
      padding: 1rem;
    }
  }
</style>
