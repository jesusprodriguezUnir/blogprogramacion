---
import BlogLayout from '../layouts/BlogLayout.astro';
import Hero from '../components/Hero.astro';

const base = (import.meta as any).env.BASE_URL || '/';

const postFilesMD = import.meta.glob('./posts/*.md', { eager: true });
const postFilesMDX = import.meta.glob('./posts/*.mdx', { eager: true });

const files = [...Object.values(postFilesMD), ...Object.values(postFilesMDX)] as any[];

const posts = files
  .map((m) => (m && m.frontmatter ? m.frontmatter : null))
  .filter(Boolean)
  .map((fm) => ({
    title: fm.title || 'Sin título',
    date: fm.date || '1970-01-01',
    excerpt: fm.excerpt || '',
    slug: fm.slug || fm.title?.toLowerCase().replace(/[^a-z0-9]+/g, '-'),
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const featuredPosts = posts.slice(0, 3);
const latestPosts = posts.slice(0, 5);

const featuredResources = [
  { title: "Documentación Claude", desc: "Guía oficial de Anthropic: API, modelos, prompt engineering y mejores prácticas", url: "https://docs.anthropic.com/", icon: "📖", tag: "Docs" },
  { title: "Claude Code Docs", desc: "Documentación del CLI: comandos, hooks, MCP servers y configuración avanzada", url: "https://docs.anthropic.com/en/docs/claude-code/overview", icon: "💻", tag: "Docs" },
  { title: "Awesome Claude", desc: "Lista curada de las mejores herramientas, integraciones y recursos de la comunidad", url: "https://awesomeclaude.ai", icon: "⭐", tag: "Directorio" },
  { title: "Skills.sh", desc: "91k+ skills reutilizables para Claude Code, Cursor, Copilot y más de 20 agentes", url: "https://skills.sh/", icon: "🚀", tag: "Skills" },
  { title: "Model Context Protocol", desc: "Especificación del protocolo MCP para conectar Claude con herramientas y datos externos", url: "https://modelcontextprotocol.io/", icon: "🔌", tag: "Protocolo" },
  { title: "Anthropic Cookbook", desc: "Ejemplos prácticos de código para las funciones más avanzadas de la API de Claude", url: "https://github.com/anthropics/anthropic-cookbook", icon: "🍳", tag: "Ejemplos" },
];

const skillCategories = [
  { icon: "🧩", name: ".NET Core",       desc: "APIs REST, EF Core, JWT, Minimal APIs, tests con xUnit" },
  { icon: "🐍", name: "Python",           desc: "FastAPI, Flask, Pandas, pytest, entornos virtuales" },
  { icon: "📘", name: "Buenas Prácticas", desc: "SOLID, Clean Code, Design Patterns, Code Review" },
  { icon: "📋", name: "Jira",             desc: "User Stories, JQL avanzado, Workflows, Sprints" },
];

const topics = ["Claude", "IA", "MCP", ".NET", "Python", "Astro", "Web Dev", "Skills", "Open Source", "API", "DevOps", "Clean Code"];
---

<BlogLayout title="DevIA Blog" description="Recursos de programación e IA para desarrolladores">
  <Hero />

  <!-- Featured Posts -->
  <div class="home-section clean-section">
    <div class="section-header-centered">
      <h2 class="section-title-mono">Featured Posts</h2>
    </div>

    <div class="cards-grid clean-cards">
      {featuredPosts.map(p => (
        <a href={`${base}posts/${p.slug}`} class="clean-card">
          <div class="clean-card-content">
            <h3 class="clean-card-title">{p.title}</h3>
            <p class="clean-card-desc">{p.excerpt}</p>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- Skills de desarrollo -->
  <div class="home-section clean-section">
    <div class="section-header-centered">
      <h2 class="section-title-mono">Skills de desarrollo</h2>
    </div>

    <div class="cards-grid clean-cards">
      {skillCategories.map(cat => (
        <a href={`${base}prompts`} class="clean-card">
          <div class="clean-card-content">
            <h3 class="clean-card-title">{cat.name}</h3>
            <p class="clean-card-desc">{cat.desc}</p>
          </div>
        </a>
      ))}
    </div>

    <div class="center-action">
      <a href={`${base}prompts`} class="btn-pill">Ver todos los skills →</a>
    </div>
  </div>

  <!-- Topics -->
  <div class="home-section topics-section">
    <h2 class="section-title-mono">Topics</h2>
    <div class="topics">
      {topics.map(t => <span class="topic">{t}</span>)}
    </div>
    <div class="center-action">
      <a href={`${base}posts`} class="btn-pill">Ver todos los tags →</a>
    </div>
  </div>

  <!-- Latest Posts -->
  <div class="home-section clean-section">
    <div class="section-header-centered">
      <h2 class="section-title-mono">Últimos Posts</h2>
    </div>
    
    <div class="latest-posts-list">
      {latestPosts.map(p => (
        <a href={`${base}posts/${p.slug}`} class="post-list-item">
          <span class="post-list-title">{p.title}</span>
          <span class="post-list-date">{new Date(p.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
        </a>
      ))}
    </div>

    <div class="center-action">
      <a href={`${base}posts`} class="btn-pill">Ver todos los posts →</a>
    </div>
  </div>
</BlogLayout>

<style>
  /* ── Section ─────────────────────────────────────────── */
  .home-section {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 40px;
    margin-bottom: 32px;
    box-shadow: var(--shadow-sm);
  }

  .clean-section {
    background: transparent;
    border: none;
    padding: 0;
    box-shadow: none;
    margin-bottom: 64px;
  }

  .section-header-centered {
    text-align: center;
    margin-bottom: 32px;
  }

  .section-title-mono {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 24px;
    font-weight: 600;
    color: var(--text);
    margin: 0;
    letter-spacing: -0.5px;
  }

  /* ── Clean Cards ─────────────────────────────────────── */
  .clean-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 32px;
  }

  .clean-card {
    display: flex;
    flex-direction: column;
    padding: 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    transition: all .2s ease;
  }

  .clean-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
    border-color: var(--text-3);
  }

  .clean-card-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--text);
    margin: 0 0 8px;
  }

  .clean-card-desc {
    font-size: 14px;
    color: var(--text-2);
    margin: 0;
    line-height: 1.5;
  }

  /* ── Latest Posts ────────────────────────────────────── */
  .latest-posts-list {
    display: flex;
    flex-direction: column;
    margin-bottom: 32px;
  }

  .post-list-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: opacity .2s;
  }

  .post-list-item:hover .post-list-title {
    color: var(--accent);
  }

  .post-list-title {
    font-size: 16px;
    font-weight: 500;
    color: var(--text);
    transition: color .2s;
  }

  .post-list-date {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    color: var(--text-3);
    flex-shrink: 0;
    margin-left: 16px;
  }

  /* ── Center Action / Pills ───────────────────────────── */
  .center-action {
    display: flex;
    justify-content: center;
    margin-top: 16px;
  }

  .btn-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 16px;
    background: var(--surface-2);
    color: var(--accent);
    font-size: 13px;
    font-weight: 600;
    border-radius: 20px;
    text-decoration: none;
    transition: all .2s ease;
  }

  .btn-pill:hover {
    background: var(--accent);
    color: #fff;
  }
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 16px;
  }

  /* ── Link card (matches enlaces.astro style) ─────────── */
  .link-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 14px;
    text-decoration: none;
    transition: all .25s ease;
    position: relative;
    overflow: hidden;
    gap: 14px;
  }

  .link-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), var(--accent-green));
    transform: scaleX(0);
    transition: transform .25s ease;
  }

  .link-card:hover {
    background: var(--surface);
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--border);
  }

  .link-card:hover::before { transform: scaleX(1); }

  .link-icon {
    flex: 0 0 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
  }

  .link-content {
    flex: 1;
    min-width: 0;
  }

  .link-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 6px;
  }

  .link-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .link-type {
    background: var(--badge-bg);
    color: var(--badge-text);
    padding: 2px 8px;
    border-radius: 5px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .4px;
    flex-shrink: 0;
  }

  .link-description {
    color: var(--text-3);
    font-size: 12px;
    line-height: 1.5;
    margin: 0 0 6px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .link-url {
    color: var(--text-3);
    font-size: 11px;
    font-family: monospace;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .link-arrow {
    font-size: 18px;
    color: var(--text-3);
    transition: all .2s ease;
    flex-shrink: 0;
  }

  .link-card:hover .link-arrow {
    color: var(--accent);
    transform: translateX(4px);
  }

  /* Skills don't show url row */
  .skill-variant .link-url { display: none; }
  .skill-variant .link-title { white-space: normal; }

  /* ── Topics ──────────────────────────────────────────── */
  .topics-section {
    padding: 0;
    background: transparent;
    border: none;
    box-shadow: none;
    text-align: center;
    margin-bottom: 64px;
  }

  .topics {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .topic {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-2);
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 5px 16px;
    cursor: default;
    transition: color .12s, background .12s, border-color .12s;
  }

  .topic:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--badge-bg);
  }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 640px) {
    .home-section { margin-bottom: 48px; }
    .section-title-mono { font-size: 20px; }
    .clean-cards { grid-template-columns: 1fr; }
    .post-list-item { flex-direction: column; gap: 4px; padding: 12px 0; }
    .post-list-date { margin-left: 0; }
  }
</style>
