---
import BlogLayout from '../layouts/BlogLayout.astro';
import Hero from '../components/Hero.astro';
import PostCard from '../components/PostCard.astro';

const base = (import.meta as any).env.BASE_URL || '/';

// Posts próximamente — por ahora sin publicaciones activas
const recentPosts: any[] = [];

---

<BlogLayout title="DevIA Blog" description="Noticias de programación e IA">
	<Hero />

	<section class="featured-section">
		<div class="section-header">
			<h2 class="section-title">Próximamente</h2>
			<p class="section-subtitle">Nuevos artículos en camino — vuelve pronto</p>
		</div>

		{recentPosts.length > 0 ? (
			<>
				<div class="posts-grid">
					{recentPosts.map(post => <PostCard {...post} />)}
				</div>
				<div class="view-all">
					<a href={`${base}posts`} class="view-all-btn">Ver todos los posts →</a>
				</div>
			</>
		) : (
			<div class="empty-posts">
				<span class="empty-icon">✍️</span>
				<p>Estamos preparando contenido nuevo. Mientras tanto, explora los <a href={`${base}enlaces`}>recursos</a> y <a href={`${base}prompts`}>skills</a>.</p>
			</div>
		)}
	</section>

</BlogLayout>

<style>
	.featured-section { margin-bottom: 48px; }
	.section-header { text-align: center; margin-bottom: 24px; }
	.section-title { font-size: 28px; font-weight: 700; color: var(--color-text-primary); }
	.section-subtitle { color: var(--color-text-secondary); }
	.posts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }
	.view-all { text-align: center; margin-top: 24px; }
	.view-all-btn { color: white; background: var(--color-accent); padding: 10px 16px; border-radius: 8px; text-decoration: none; transition: background 0.2s; }
	.view-all-btn:hover { background: var(--color-accent-hover); }
	.empty-posts { text-align: center; padding: 48px 24px; background: var(--color-surface); border-radius: 16px; border: 1px dashed var(--color-border); }
	.empty-icon { font-size: 48px; display: block; margin-bottom: 16px; }
	.empty-posts p { color: var(--color-text-secondary); font-size: 16px; line-height: 1.6; margin: 0; }
	.empty-posts a { color: var(--color-accent); text-decoration: none; font-weight: 600; }
	.empty-posts a:hover { text-decoration: underline; }
</style>