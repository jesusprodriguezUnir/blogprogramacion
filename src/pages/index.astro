---
import BlogLayout from '../layouts/BlogLayout.astro';
import Hero from '../components/Hero.astro';

const base = (import.meta as any).env.BASE_URL || '/';

const featuredResources = [
  { title: "Documentación Claude", desc: "Guía oficial de Anthropic: API, modelos, prompt engineering y mejores prácticas", url: "https://docs.anthropic.com/", icon: "📖", tag: "Docs" },
  { title: "Claude Code Docs", desc: "Documentación del CLI: comandos, hooks, MCP servers y configuración avanzada", url: "https://docs.anthropic.com/en/docs/claude-code/overview", icon: "💻", tag: "Docs" },
  { title: "Awesome Claude", desc: "Lista curada de las mejores herramientas, integraciones y recursos de la comunidad", url: "https://awesomeclaude.ai", icon: "⭐", tag: "Directorio" },
  { title: "Skills.sh", desc: "91k+ skills reutilizables para Claude Code, Cursor, Copilot y más de 20 agentes", url: "https://skills.sh/", icon: "🚀", tag: "Skills" },
  { title: "Model Context Protocol", desc: "Especificación del protocolo MCP para conectar Claude con herramientas y datos externos", url: "https://modelcontextprotocol.io/", icon: "🔌", tag: "Protocolo" },
  { title: "Anthropic Cookbook", desc: "Ejemplos prácticos de código para las funciones más avanzadas de la API de Claude", url: "https://github.com/anthropics/anthropic-cookbook", icon: "🍳", tag: "Ejemplos" },
];

const skillCategories = [
  { icon: "🧩", name: ".NET Core",       desc: "APIs REST, EF Core, JWT, Minimal APIs, tests con xUnit" },
  { icon: "🐍", name: "Python",           desc: "FastAPI, Flask, Pandas, pytest, entornos virtuales" },
  { icon: "📘", name: "Buenas Prácticas", desc: "SOLID, Clean Code, Design Patterns, Code Review" },
  { icon: "📋", name: "Jira",             desc: "User Stories, JQL avanzado, Workflows, Sprints" },
];

const topics = ["Claude", "IA", "MCP", ".NET", "Python", "Astro", "Web Dev", "Skills", "Open Source", "API", "DevOps", "Clean Code"];
---

<BlogLayout title="DevIA Blog" description="Recursos de programación e IA para desarrolladores">
  <Hero />

  <!-- Recursos destacados -->
  <div class="home-section">
    <div class="section-header">
      <div class="section-icon">🧠</div>
      <div class="section-info">
        <h2 class="section-title">Recursos destacados</h2>
        <p class="section-desc">Los mejores enlaces para aprender y trabajar con Claude e IA</p>
      </div>
    </div>

    <div class="cards-grid">
      {featuredResources.map(r => (
        <a href={r.url} class="link-card" target="_blank" rel="noopener noreferrer">
          <div class="link-icon">{r.icon}</div>
          <div class="link-content">
            <div class="link-header">
              <h3 class="link-title">{r.title}</h3>
              <span class="link-type">{r.tag}</span>
            </div>
            <p class="link-description">{r.desc}</p>
            <div class="link-url">{r.url.replace('https://', '')}</div>
          </div>
          <div class="link-arrow">→</div>
        </a>
      ))}
    </div>

    <a href={`${base}enlaces`} class="see-all">Ver todos los recursos →</a>
  </div>

  <!-- Skills de desarrollo -->
  <div class="home-section">
    <div class="section-header">
      <div class="section-icon">🎯</div>
      <div class="section-info">
        <h2 class="section-title">Skills de desarrollo</h2>
        <p class="section-desc">Prompts listos para usar con cualquier modelo de IA</p>
      </div>
    </div>

    <div class="cards-grid">
      {skillCategories.map(cat => (
        <a href={`${base}prompts`} class="link-card skill-variant">
          <div class="link-icon">{cat.icon}</div>
          <div class="link-content">
            <h3 class="link-title">{cat.name}</h3>
            <p class="link-description">{cat.desc}</p>
          </div>
          <div class="link-arrow">→</div>
        </a>
      ))}
    </div>

    <a href={`${base}prompts`} class="see-all">Ver todos los skills →</a>
  </div>

  <!-- Topics -->
  <div class="home-section topics-section">
    <h2 class="topics-heading">Temas</h2>
    <div class="topics">
      {topics.map(t => <span class="topic">{t}</span>)}
    </div>
  </div>
</BlogLayout>

<style>
  /* ── Section ─────────────────────────────────────────── */
  .home-section {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 40px;
    margin-bottom: 32px;
    box-shadow: var(--shadow-sm);
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 28px;
  }

  .section-icon {
    font-size: 36px;
    background: var(--surface-2);
    width: 64px;
    height: 64px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border: 1px solid var(--border);
  }

  .section-title {
    font-size: 22px;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 4px;
    letter-spacing: -.3px;
  }

  .section-desc {
    font-size: 14px;
    color: var(--text-3);
    margin: 0;
  }

  .see-all {
    display: inline-block;
    margin-top: 20px;
    font-size: 13px;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
  }

  .see-all:hover { text-decoration: underline; }

  /* ── Cards grid ──────────────────────────────────────── */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 16px;
  }

  /* ── Link card (matches enlaces.astro style) ─────────── */
  .link-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 14px;
    text-decoration: none;
    transition: all .25s ease;
    position: relative;
    overflow: hidden;
    gap: 14px;
  }

  .link-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), var(--accent-green));
    transform: scaleX(0);
    transition: transform .25s ease;
  }

  .link-card:hover {
    background: var(--surface);
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--border);
  }

  .link-card:hover::before { transform: scaleX(1); }

  .link-icon {
    flex: 0 0 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
  }

  .link-content {
    flex: 1;
    min-width: 0;
  }

  .link-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 6px;
  }

  .link-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .link-type {
    background: var(--badge-bg);
    color: var(--badge-text);
    padding: 2px 8px;
    border-radius: 5px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .4px;
    flex-shrink: 0;
  }

  .link-description {
    color: var(--text-3);
    font-size: 12px;
    line-height: 1.5;
    margin: 0 0 6px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .link-url {
    color: var(--text-3);
    font-size: 11px;
    font-family: monospace;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .link-arrow {
    font-size: 18px;
    color: var(--text-3);
    transition: all .2s ease;
    flex-shrink: 0;
  }

  .link-card:hover .link-arrow {
    color: var(--accent);
    transform: translateX(4px);
  }

  /* Skills don't show url row */
  .skill-variant .link-url { display: none; }
  .skill-variant .link-title { white-space: normal; }

  /* ── Topics ──────────────────────────────────────────── */
  .topics-section {
    padding: 32px 40px;
  }

  .topics-heading {
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 18px;
    letter-spacing: -.2px;
  }

  .topics {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .topic {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-2);
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 5px 16px;
    cursor: default;
    transition: color .12s, background .12s, border-color .12s;
  }

  .topic:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--badge-bg);
  }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 640px) {
    .home-section { padding: 24px 20px; }
    .topics-section { padding: 24px 20px; }
    .section-icon { width: 48px; height: 48px; font-size: 26px; border-radius: 12px; }
    .section-title { font-size: 18px; }
    .cards-grid { grid-template-columns: 1fr; gap: 12px; }
    .link-card { padding: 16px; }
    .link-icon { flex: 0 0 44px; height: 44px; font-size: 20px; }
    .link-url { display: none; }
    .link-type { display: none; }
  }
</style>
