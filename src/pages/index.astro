---
import BlogLayout from '../layouts/BlogLayout.astro';
import Hero from '../components/Hero.astro';

const base = (import.meta as any).env.BASE_URL || '/';

const postFilesMD = import.meta.glob('./posts/*.md', { eager: true });
const postFilesMDX = import.meta.glob('./posts/*.mdx', { eager: true });

const files = [...Object.values(postFilesMD), ...Object.values(postFilesMDX)] as any[];

const posts = files
  .map((m) => (m && m.frontmatter ? m.frontmatter : null))
  .filter(Boolean)
  .map((fm) => ({
    title: fm.title || 'Sin título',
    date: fm.date || '1970-01-01',
    excerpt: fm.excerpt || '',
    slug: fm.slug || fm.title?.toLowerCase().replace(/[^a-z0-9]+/g, '-'),
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const featuredResources = [
  { title: "Documentación Claude", desc: "Guía oficial de Anthropic: API, modelos, prompt engineering y mejores prácticas", url: "https://docs.anthropic.com/", icon: "📖", tag: "Docs" },
  { title: "Claude Code Docs", desc: "Documentación del CLI: comandos, hooks, MCP servers y configuración avanzada", url: "https://docs.anthropic.com/en/docs/claude-code/overview", icon: "💻", tag: "Docs" },
  { title: "Awesome Claude", desc: "Lista curada de las mejores herramientas, integraciones y recursos de la comunidad", url: "https://awesomeclaude.ai", icon: "⭐", tag: "Directorio" },
];

const skillCategories = [
  { icon: "🧩", name: ".NET Core",       desc: "APIs REST, EF Core, JWT, Minimal APIs, tests con xUnit" },
  { icon: "🐍", name: "Python",           desc: "FastAPI, Flask, Pandas, pytest, entornos virtuales" },
  { icon: "📘", name: "Buenas Prácticas", desc: "SOLID, Clean Code, Design Patterns, Code Review" },
  { icon: "📋", name: "Jira",             desc: "User Stories, JQL avanzado, Workflows, Sprints" },
];

const topics = ["Claude", "IA", "MCP", ".NET", "Python", "Astro", "Web Dev", "Skills", "API", "Clean Code"];
---

<BlogLayout title="jesus_rodriguez // dev_blog" description="Arquitectura de software, .NET, IA y desarrollo full-stack">
  <Hero />

  <!-- Skills -->
  <section class="home-section">
    <div class="section-header">
      <h2 class="section-title mono"><span class="accent">[ 01 ]</span> tech_stack</h2>
    </div>

    <div class="cards-grid">
      {skillCategories.map(cat => (
        <a href={`${base}prompts`} class="skill-card glass glow-on-hover">
          <div class="card-icon">{cat.icon}</div>
          <div class="card-content">
            <h3 class="card-title mono">{cat.name}</h3>
            <p class="card-desc">{cat.desc}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Latest Posts -->
  <section class="home-section">
    <div class="section-header">
      <h2 class="section-title mono"><span class="accent">[ 02 ]</span> recent_entries</h2>
    </div>
    
    <div class="posts-list glass">
      {posts.slice(0, 5).map(p => (
        <a href={`${base}posts/${p.slug}`} class="post-item">
          <div class="post-info">
            <span class="post-date mono">{new Date(p.date).toLocaleDateString('en-US', { month: '2-digit', day: '2-digit', year: '2-digit' }).replace(/\//g, '.')}</span>
            <span class="post-title mono">{p.title}</span>
          </div>
          <span class="post-arrow mono">-></span>
        </a>
      ))}
    </div>

    <div class="center-action">
      <a href={`${base}posts`} class="btn-link mono">ls ./posts --all</a>
    </div>
  </section>

  <!-- Topics -->
  <section class="home-section">
    <div class="section-header">
      <h2 class="section-title mono"><span class="accent">[ 03 ]</span> tags_cloud</h2>
    </div>
    <div class="topics-cloud">
      {topics.map(t => <span class="topic-tag glass mono">{t}</span>)}
    </div>
  </section>
</BlogLayout>

<style>
  .home-section {
    margin-bottom: 6rem;
  }

  .section-header {
    margin-bottom: 2rem;
  }

  .section-title {
    font-size: 1.25rem;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .accent {
    color: var(--accent);
    font-weight: 700;
  }

  /* Cards Grid */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .skill-card {
    display: flex;
    gap: 1.25rem;
    padding: 1.5rem;
    transition: all 0.3s var(--ease);
    border: 1px solid var(--border);
  }

  .skill-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow: 0 8px 25px var(--accent-soft);
  }

  .card-icon {
    font-size: 1.5rem;
    background: var(--bg-soft);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    border: 1px solid var(--border);
    transition: all 0.3s var(--ease);
  }

  .skill-card:hover .card-icon {
    background: var(--accent-soft);
    border-color: var(--accent);
    transform: scale(1.1);
  }

  .card-title {
    font-size: 1rem;
    margin-bottom: 0.5rem;
    color: var(--text);
    transition: color 0.3s var(--ease);
  }

  .skill-card:hover .card-title {
    color: var(--accent);
  }

  .card-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* Posts List */
  .posts-list {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .post-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--border);
    transition: all 0.3s var(--ease);
  }

  .post-item:last-child {
    border-bottom: none;
  }

  .post-item:hover {
    background: var(--surface-hover);
    padding-left: 1.75rem;
  }

  .post-item:hover .post-title {
    color: var(--accent);
  }

  .post-info {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .post-date {
    font-size: 0.85rem;
    color: var(--text-dim);
    min-width: 80px;
    font-family: var(--font-mono);
  }

  .post-title {
    font-size: 1rem;
    color: var(--text-muted);
    transition: color 0.3s var(--ease);
    font-weight: 500;
  }

  .post-arrow {
    color: var(--text-dim);
    transition: all 0.3s var(--ease);
  }

  .post-item:hover .post-arrow {
    transform: translateX(4px);
    color: var(--accent);
  }

  .center-action {
    display: flex;
    justify-content: center;
    margin-top: 2rem;
  }

  .btn-link {
    color: var(--text-dim);
    font-size: 0.9rem;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    transition: all 0.3s var(--ease);
    background: var(--surface);
  }

  .btn-link:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-soft);
    box-shadow: 0 0 15px var(--accent-soft);
  }

  /* Topics */
  .topics-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .topic-tag {
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    border-radius: 8px;
    cursor: pointer;
    border: 1px solid var(--border);
    transition: all 0.3s var(--ease);
  }

  .topic-tag:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-soft);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px var(--accent-soft);
  }

  @media (max-width: 640px) {
    .post-info { gap: 1rem; }
    .post-date { min-width: 60px; font-size: 0.75rem; }
    .post-title { font-size: 0.9rem; }
  }
</style>
