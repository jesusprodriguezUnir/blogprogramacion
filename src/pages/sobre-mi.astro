---
import BlogLayout from '../layouts/BlogLayout.astro';
const base = (import.meta as any).env.BASE_URL || '/';
---

<BlogLayout title="jesus_rodriguez // about" description="Conoce a Jesús Pedro Rodríguez Castro, Arquitecto de Software y Tech Lead.">
  <div class="about-container">
    <div class="profile-header glass">
      <div class="avatar-wrapper">
        <img src={`${base}assets/profile.jpg`} alt="Jesús Pedro" class="avatar" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
        <div class="avatar-fallback mono">JP</div>
      </div>
      <div class="profile-meta">
        <h1 class="name mono">Jesús Pedro Rodríguez Castro</h1>
        <p class="role mono">Technical Lead Full Stack & Scrum Master</p>
        <div class="status mono"><span class="pulse"></span> Online // Available for architecture review</div>
      </div>
    </div>

    <section class="about-section glass">
      <h2 class="section-title mono"><span class="accent">></span> whoami</h2>
      <div class="section-content">
        <p>
          Arquitecto de Software con una sólida trayectoria liderando equipos multidisciplinares y gestionando flujos de trabajo ágiles. 
          Especializado en el desarrollo de sistemas escalables utilizando el ecosistema <strong>.NET</strong> y arquitecturas modernas de Frontend.
        </p>
        <p>
          Mi enfoque se centra en la excelencia técnica, el código limpio y la implementación de soluciones que aporten valor real al negocio. 
          Actualmente exploro las posibilidades de la <strong>IA Generativa</strong> aplicada a la productividad del desarrollador y la automatización de procesos.
        </p>
      </div>
    </section>

    <div class="about-grid">
      <section class="about-section glass">
        <h2 class="section-title mono"><span class="accent">></span> experience.log</h2>
        <div class="experience-list">
          <div class="exp-item">
            <span class="exp-date mono">2021 - Present</span>
            <div class="exp-info">
              <h3 class="exp-title mono">Software Architect</h3>
              <p class="exp-company">Plain Concepts</p>
            </div>
          </div>
          <div class="exp-item">
            <span class="exp-date mono">2018 - 2021</span>
            <div class="exp-info">
              <h3 class="exp-title mono">Tech Lead Full Stack</h3>
              <p class="exp-company">UNIR</p>
            </div>
          </div>
        </div>
      </section>

      <section class="about-section glass">
        <h2 class="section-title mono"><span class="accent">></span> core_skills</h2>
        <div class="skills-tags">
          <span class="skill-tag glass mono">.NET Core</span>
          <span class="skill-tag glass mono">C#</span>
          <span class="skill-tag glass mono">Azure</span>
          <span class="skill-tag glass mono">React / Angular</span>
          <span class="skill-tag glass mono">Scrum</span>
          <span class="skill-tag glass mono">Architecture</span>
          <span class="skill-tag glass mono">Clean Code</span>
          <span class="skill-tag glass mono">CI/CD</span>
        </div>
      </section>
    </div>

    <div class="center-action">
      <a href="https://linkedin.com/" target="_blank" rel="noopener" class="btn btn-primary mono">
        connect --network linkedin
      </a>
    </div>
  </div>
</BlogLayout>

<style>
  .about-container {
    max-width: 800px;
    margin: 2rem auto;
  }

  .profile-header {
    display: flex;
    gap: 2.5rem;
    padding: 2.5rem;
    margin-bottom: 3rem;
    align-items: center;
  }

  .avatar-wrapper {
    width: 120px;
    height: 120px;
    flex-shrink: 0;
    position: relative;
  }

  .avatar {
    width: 100%;
    height: 100%;
    border-radius: 20px;
    object-fit: cover;
    border: 2px solid var(--accent);
  }

  .avatar-fallback {
    width: 100%;
    height: 100%;
    border-radius: 20px;
    background: var(--bg-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent);
    border: 2px solid var(--border);
  }

  .name {
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .role {
    color: var(--accent);
    font-size: 1rem;
    margin-bottom: 1rem;
  }

  .status {
    font-size: 0.8rem;
    color: var(--text-dim);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 0 rgba(103, 232, 249, 0.4); /* Cyan/Green shadow */
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 oklch(0.72 0.18 145 / 0.7); }
    70% { box-shadow: 0 0 0 10px oklch(0.72 0.18 145 / 0); }
    100% { box-shadow: 0 0 0 0 oklch(0.72 0.18 145 / 0); }
  }

  .about-section {
    padding: 2rem;
    margin-bottom: 2rem;
  }

  .section-title {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
    color: var(--text);
  }

  .accent {
    color: var(--accent);
  }

  .section-content p {
    color: var(--text-muted);
    margin-bottom: 1.25rem;
    line-height: 1.7;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 2rem;
  }

  .experience-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .exp-item {
    display: flex;
    gap: 1.5rem;
  }

  .exp-date {
    font-size: 0.8rem;
    color: var(--text-dim);
    min-width: 90px;
    padding-top: 0.2rem;
  }

  .exp-title {
    font-size: 1rem;
    margin-bottom: 0.25rem;
    color: var(--text);
  }

  .exp-company {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .skills-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .skill-tag {
    padding: 0.4rem 0.8rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    border-radius: 6px;
  }

  .center-action {
    display: flex;
    justify-content: center;
    margin-top: 3rem;
  }

  .btn {
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-size: 0.9rem;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: var(--accent);
    color: white;
    box-shadow: 0 4px 15px var(--accent-soft);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px var(--accent-glow);
  }

  @media (max-width: 768px) {
    .profile-header { flex-direction: column; text-align: center; }
    .about-grid { grid-template-columns: 1fr; }
    .exp-item { flex-direction: column; gap: 0.5rem; }
    .exp-date { min-width: auto; }
  }
</style>
