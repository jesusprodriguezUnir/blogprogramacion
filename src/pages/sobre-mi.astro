
---
import BlogLayout from '../layouts/BlogLayout.astro';
---

<BlogLayout title="Sobre mí" description="Conoce al autor de DevIA Blog y accede a su blog personal.">
  <section class="about-section">
    <div class="about-content">
      <div class="about-avatar">
        <img src="/assets/profile.jpg" alt="Foto de Jesús P." class="avatar-img" onerror="this.src='/assets/astro.svg'" />
      </div>
      <div class="about-text">
        <h1 class="about-title">Sobre mí</h1>
        <p class="about-description">
          ¡Hola! Soy el autor de este blog. Apasionado por la programación, la inteligencia artificial y la divulgación tecnológica. Aquí comparto noticias, recursos y reflexiones para la comunidad dev.
        </p>
        <a href="https://blogpersonal-eta.vercel.app/" class="about-link" target="_blank" rel="noopener noreferrer">
          Visita mi blog personal
        </a>
      </div>
    </div>
  </section>
</BlogLayout>

<style>
.about-section {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
  background: transparent;
  margin: 64px auto;
  max-width: 800px;
  padding: 40px 20px;
}
.about-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40px;
  text-align: center;
}
.about-avatar {
  flex-shrink: 0;
}
.avatar-img {
  width: 200px;
  height: 200px;
  border-radius: 50%;
  border: 4px solid var(--accent);
  box-shadow: 0 0 20px rgba(74, 144, 217, 0.3);
  padding: 4px;
  background: var(--bg);
  object-fit: cover;
}
.about-text {
  max-width: 600px;
}
.about-title {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 3rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 24px;
  letter-spacing: -1px;
}
.about-description {
  font-size: 1.15rem;
  color: var(--text-2);
  line-height: 1.8;
  margin-bottom: 32px;
}
.about-link {
  display: inline-flex;
  background: var(--surface-2);
  color: var(--accent);
  padding: 12px 24px;
  border-radius: 24px;
  font-weight: 600;
  font-size: 1rem;
  text-decoration: none;
  transition: all 0.2s;
}
.about-link:hover {
  background: var(--accent);
  color: #fff;
}
@media (max-width: 768px) {
  .about-title {
    font-size: 2.5rem;
  }
}
</style>
