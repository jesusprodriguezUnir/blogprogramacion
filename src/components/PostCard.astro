---
import { normalizeBase, postHref } from '../utils/url';
import { getCategoryColor } from '../utils/category';

const rawBase = (import.meta as any).env.BASE_URL;
const base = normalizeBase(rawBase);

interface Props {
	title: string;
	excerpt: string;
	date: string;
	category: string;
	slug: string;
	readTime?: string;
}

const { title, excerpt, date, category, slug, readTime = "3 min" } = Astro.props;

const categoryColor = getCategoryColor(category);
---

<article class="post-card">
	<div class="post-category">
		<span class={`category-tag ${categoryColor}`}>{category}</span>
		<span class="post-date">{date}</span>
	</div>
	
	<h2 class="post-title">
		<a href={postHref(rawBase, slug)} class="post-link">{title}</a>
	</h2>
	
	<p class="post-excerpt">{excerpt}</p>
	
	<div class="post-meta">
		<span class="read-time">📖 {readTime} de lectura</span>
	<a href={postHref(rawBase, slug)} class="read-more">Leer más →</a>
	</div>
</article>

<style>
	.post-card {
		background: var(--surface);
		border-radius: 16px;
		padding: 32px;
		box-shadow: 0 4px 15px rgba(0,0,0,0.2);
		transition: all 0.3s var(--ease);
		border: 1px solid var(--border);
		position: relative;
		overflow: hidden;
	}

	.post-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 4px;
		background: linear-gradient(90deg, var(--accent), var(--secondary), var(--success));
		opacity: 0.2;
		transition: opacity 0.3s var(--ease);
	}

	.post-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 12px 30px rgba(0,0,0,0.4);
		border-color: var(--accent-soft);
	}

	.post-card:hover::before {
		opacity: 1;
	}

	.post-category {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 16px;
	}

	.category-tag {
		display: inline-block;
		padding: 4px 12px;
		border-radius: 6px;
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		font-family: var(--font-mono);
		color: var(--bg);
	}

	.bg-green-500 { background-color: var(--success); }
	.bg-blue-500 { background-color: var(--accent); }
	.bg-purple-500 { background-color: var(--secondary); }
	.bg-orange-500 { background-color: var(--amber); }
	.bg-gray-500 { background-color: var(--text-muted); }

	.post-date {
		font-size: 13px;
		color: var(--text-dim);
		font-family: var(--font-mono);
		font-weight: 500;
	}

	.post-title {
		font-size: 22px;
		font-weight: 700;
		line-height: 1.3;
		margin-bottom: 16px;
		letter-spacing: -0.01em;
	}

	.post-link {
		color: var(--text);
		text-decoration: none;
		transition: color 0.2s var(--ease);
	}

	.post-card:hover .post-link {
		color: var(--accent);
	}

	.post-excerpt {
		color: var(--text-muted);
		font-size: 15px;
		line-height: 1.7;
		margin-bottom: 24px;
	}

	.post-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding-top: 16px;
		border-top: 1px solid var(--border);
	}

	.read-time {
		font-size: 13px;
		color: var(--text-dim);
		display: flex;
		align-items: center;
		gap: 8px;
		font-family: var(--font-mono);
	}

	.read-more {
		color: var(--accent);
		font-weight: 600;
		text-decoration: none;
		font-size: 13px;
		font-family: var(--font-mono);
		transition: all 0.2s var(--ease);
		padding: 6px 12px;
		border-radius: 6px;
		background: var(--accent-soft);
	}

	.read-more:hover {
		background: var(--accent-glow);
		color: var(--bg);
		transform: translateX(4px);
	}

	@media (max-width: 768px) {
		.post-card {
			padding: 24px;
		}

		.post-title {
			font-size: 20px;
		}

		.post-meta {
			flex-direction: column;
			align-items: flex-start;
			gap: 12px;
		}
	}
</style>