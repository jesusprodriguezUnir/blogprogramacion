---
const base = (import.meta as any).env.BASE_URL || '/';
---
<section class="hero">

  <!-- LEFT: bio -->
  <div class="hero-body">
    <span class="hero-badge">
      <span class="badge-dot"></span>
      Disponible para colaborar
    </span>

    <h1 class="hero-name">Jesús P.</h1>
    <p class="hero-title">Desarrollador <span class="dot">·</span> Entusiasta IA</p>

    <p class="hero-bio">
      Apasionado por la programación y la inteligencia artificial.
      Comparto recursos, skills y noticias para la comunidad dev en español.
    </p>

    <div class="hero-actions">
      <a href="https://blogpersonal-eta.vercel.app/" target="_blank" rel="noopener" class="btn-primary">
        Blog personal
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/>
        </svg>
      </a>
      <div class="socials">
        <a href="https://github.com/jesusprodriguezUnir" target="_blank" rel="noopener" aria-label="GitHub" class="social-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          GitHub
        </a>
        <a href="https://linkedin.com/" target="_blank" rel="noopener" aria-label="LinkedIn" class="social-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>

    <div class="hero-stack">
      <span class="stack-tag">Claude</span>
      <span class="stack-tag">.NET</span>
      <span class="stack-tag">Python</span>
      <span class="stack-tag">Astro</span>
      <span class="stack-tag">IA</span>
    </div>
  </div>

  <!-- RIGHT: photo -->
  <div class="hero-visual">
    <div class="photo-frame">
      <img
        src={`${base}assets/profile.jpg`}
        alt="Jesús P."
        class="photo"
        onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
      />
      <div class="photo-fallback">JP</div>
    </div>
  </div>

</section>

<style>
  /* ─── Layout ─────────────────────────────────────── */
  .hero {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 56px;
    padding: 64px 0 60px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 64px;
  }

  /* ─── Left column ────────────────────────────────── */
  .hero-body {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 12px;
    font-weight: 500;
    color: var(--accent-green);
    background: color-mix(in srgb, var(--accent-green) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent-green) 25%, transparent);
    border-radius: 20px;
    padding: 4px 12px 4px 8px;
    width: fit-content;
    margin-bottom: 20px;
  }

  .badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent-green);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: .4; }
  }

  .hero-name {
    font-size: clamp(36px, 5vw, 52px);
    font-weight: 700;
    color: var(--text);
    margin: 0 0 6px;
    letter-spacing: -1.5px;
    line-height: 1.1;
  }

  .hero-title {
    font-size: 16px;
    font-weight: 500;
    color: var(--text-2);
    margin: 0 0 20px;
    letter-spacing: .1px;
  }

  .dot { color: var(--text-3); margin: 0 2px; }

  .hero-bio {
    font-size: 15px;
    color: var(--text-2);
    line-height: 1.7;
    margin: 0 0 28px;
    max-width: 440px;
  }

  /* Actions */
  .hero-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 28px;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 14px;
    font-weight: 600;
    color: #fff;
    background: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 8px;
    padding: 9px 18px;
    text-decoration: none;
    transition: background .15s, opacity .15s;
  }

  .btn-primary:hover { opacity: .9; }

  .socials {
    display: flex;
    gap: 6px;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-2);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 8px 12px;
    text-decoration: none;
    transition: color .15s, border-color .15s, background .15s;
  }

  .social-btn:hover {
    color: var(--text);
    border-color: var(--text-3);
    background: var(--surface-2);
  }

  /* Stack tags */
  .hero-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .stack-tag {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-3);
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 3px 9px;
    letter-spacing: .3px;
    text-transform: uppercase;
  }

  /* ─── Right column — photo ────────────────────────── */
  .hero-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .photo-frame {
    position: relative;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    padding: 3px;
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-purple) 100%);
    box-shadow: 0 0 0 6px var(--surface-2), var(--shadow-md);
  }

  .photo {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    background: var(--surface-2);
  }

  .photo-fallback {
    display: none;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: var(--surface-2);
    color: var(--text-2);
    font-size: 36px;
    font-weight: 700;
    align-items: center;
    justify-content: center;
  }

  /* ─── Responsive ─────────────────────────────────── */
  @media (max-width: 680px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 40px 0 40px;
      margin-bottom: 48px;
      text-align: center;
    }

    .hero-visual { order: -1; }

    .photo-frame { width: 120px; height: 120px; }

    .hero-badge { margin: 0 auto 16px; }

    .hero-bio { max-width: 100%; }

    .hero-actions { justify-content: center; }

    .hero-stack { justify-content: center; }
  }
</style>
