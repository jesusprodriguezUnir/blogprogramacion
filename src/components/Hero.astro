---
const base = (import.meta as any).env.BASE_URL || '/';
---

<section class="hero">
  <div class="hero-grid">
    <div class="hero-main">
      <p class="eyebrow mono">software engineer · .net · ia · madrid</p>
      <h1 class="hero-title">
        Jesús Pedro
        <span>Rodríguez Castro</span>
      </h1>
      <p class="hero-description">
        Construyo software útil con foco en <strong>arquitectura .NET, frontend moderno e IA aplicada</strong>.
        Este blog resume decisiones técnicas, aprendizajes y recursos prácticos para equipos reales.
      </p>
      <div class="hero-actions">
        <a href={`${base}sobre-mi`} class="btn btn-primary mono">ver_perfil</a>
        <a href="https://github.com/jesusprodriguezUnir" target="_blank" rel="noopener" class="btn btn-secondary mono">github_profile</a>
      </div>
    </div>

    <aside class="hero-side glass">
      <p class="eyebrow mono">snapshot</p>
      <div class="side-list">
        <p><span class="idx mono">01</span> Technical Lead Full Stack + Scrum Master.</p>
        <p><span class="idx mono">02</span> Backend robusto, frontend mantenible y delivery continuo.</p>
        <p><span class="idx mono">03</span> Productividad con IA aplicada a desarrollo y procesos.</p>
      </div>
    </aside>
  </div>
</section>

<style>
  .hero {
    padding: 3.4rem 0 1.4rem;
  }

  .hero-grid {
    display: grid;
    gap: 1.2rem;
    grid-template-columns: 1.25fr 0.75fr;
    align-items: end;
  }

  .eyebrow {
    color: var(--text-dim);
    font-size: 0.67rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .hero-title {
    font-family: var(--font-ui);
    font-size: clamp(2rem, 5.4vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }

  .hero-title span {
    display: block;
    color: var(--accent);
  }

  .hero-description {
    color: var(--text-muted);
    font-size: 1.08rem;
    line-height: 1.72;
    max-width: 62ch;
  }

  .hero-description strong {
    color: var(--text);
    font-family: var(--font-ui);
  }

  .hero-actions {
    margin-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.62rem 1.15rem;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border: 1px solid var(--border);
  }

  .btn-primary {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
  }

  .btn-primary:hover {
    filter: brightness(1.06);
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: var(--surface);
    color: var(--text);
  }

  .btn-secondary:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .hero-side {
    padding: 1.2rem;
  }

  .side-list {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .idx {
    color: var(--accent);
    margin-right: 0.5rem;
    font-size: 0.7rem;
    letter-spacing: 0.16em;
  }

  @media (max-width: 860px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
