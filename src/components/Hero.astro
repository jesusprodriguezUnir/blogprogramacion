---
const base = (import.meta as any).env.BASE_URL || '/';
---
<section class="hero">

  <!-- LEFT: bio -->
  <div class="hero-body">
    <h1 class="hero-name">Jesús P.</h1>
    <p class="hero-title">Software Architect at Plain Concepts</p>

    <div class="hero-actions">
      <div class="socials">
        <a href="https://github.com/jesusprodriguezUnir" target="_blank" rel="noopener" aria-label="GitHub" class="social-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          GitHub
        </a>
        <a href="https://linkedin.com/" target="_blank" rel="noopener" aria-label="LinkedIn" class="social-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </div>
      </div>
    </div>
  </div>

  <!-- RIGHT: photo -->
  <div class="hero-visual">
    <div class="photo-frame">
      <img
        src={`${base}assets/profile.jpg`}
        alt="Jesús P."
        class="photo"
        onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
      />
      <div class="photo-fallback">JP</div>
    </div>
  </div>

</section>

<style>
  /* ─── Layout ─────────────────────────────────────── */
  .hero {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 56px;
    padding: 120px 0 100px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 64px;
  }

  /* ─── Left column ────────────────────────────────── */
  .hero-body {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hero-name {
    font-family: 'IBM Plex Mono', monospace;
    font-size: clamp(42px, 6vw, 64px);
    font-weight: 700;
    color: var(--text);
    margin: 0 0 12px;
    letter-spacing: -1.5px;
    line-height: 1.1;
  }

  .hero-title {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 18px;
    font-weight: 500;
    color: var(--text-2);
    margin: 0 0 32px;
    letter-spacing: .1px;
  }

  /* Actions */
  .hero-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .socials {
    display: flex;
    gap: 6px;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-2);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 8px 16px;
    text-decoration: none;
    transition: all .2s ease;
  }

  .social-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--badge-bg);
  }

  /* ─── Right column — photo ────────────────────────── */
  .hero-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .photo-frame {
    position: relative;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    border: 4px solid var(--accent);
    box-shadow: 0 0 20px rgba(74, 144, 217, 0.3);
    padding: 4px;
    background: var(--bg);
  }

  .photo {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    background: var(--surface-2);
  }

  .photo-fallback {
    display: none;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: var(--surface-2);
    color: var(--text-2);
    font-size: 36px;
    font-weight: 700;
    align-items: center;
    justify-content: center;
  }

  /* ─── Responsive ─────────────────────────────────── */
  @media (max-width: 680px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 60px 0;
      text-align: center;
    }

    .hero-visual { order: -1; }

    .photo-frame { width: 160px; height: 160px; }

    .hero-actions { justify-content: center; }
  }
</style>
