---
const base = (import.meta as any).env.BASE_URL || '/';
---
<section class="hero">
  <div class="hero-content">
    <div class="terminal-header glass">
      <div class="dots">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
      </div>
      <div class="terminal-title mono">bash — jesus_rodriguez</div>
    </div>
    
    <div class="terminal-body glass">
      <div class="command-line">
        <span class="prompt mono">jesus_rodriguez /></span>
        <span class="typing-text mono">whoami</span>
      </div>
      
      <div class="response">
        <h1 class="name mono">Jesús Pedro Rodríguez Castro</h1>
        <p class="role mono">Technical Lead Full Stack & Scrum Master</p>
        <p class="description">
          Arquitecto de Software especializado en el ecosistema .NET y tecnologías Frontend modernas. 
          Apasionado por la Inteligencia Artificial, los sistemas distribuidos y las buenas prácticas de ingeniería.
        </p>
      </div>

      <div class="hero-actions">
        <a href="https://github.com/jesusprodriguezUnir" target="_blank" rel="noopener" class="btn btn-primary mono">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          github --follow
        </a>
        <a href={`${base}sobre-mi`} class="btn btn-secondary mono">
          view_profile --full
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 4rem 0;
  }

  .terminal-header {
    border-bottom: none;
    border-radius: 12px 12px 0 0;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    background: rgba(13, 13, 13, 0.8);
  }

  .dots {
    display: flex;
    gap: 0.5rem;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .red { background: #ff5f56; }
  .yellow { background: #ffbd2e; }
  .green { background: #27c93f; }

  .terminal-title {
    margin-left: auto;
    margin-right: auto;
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  .terminal-body {
    border-top: 1px solid var(--border);
    border-radius: 0 0 12px 12px;
    padding: 2rem;
    background: rgba(5, 5, 5, 0.6);
  }

  .command-line {
    margin-bottom: 2rem;
    display: flex;
    gap: 0.75rem;
  }

  .prompt {
    color: var(--accent);
    font-weight: 600;
  }

  .typing-text {
    border-right: 2px solid var(--accent);
    white-space: nowrap;
    overflow: hidden;
    width: 0;
    animation: typing 2s steps(6, end) forwards, blink 1s infinite;
  }

  @keyframes typing {
    from { width: 0; }
    to { width: 5.5ch; }
  }

  @keyframes blink {
    50% { border-color: transparent; }
  }

  .response {
    opacity: 0;
    animation: fadeIn 0.5s ease forwards 2.5s;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .name {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    background: linear-gradient(to right, var(--text), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .role {
    font-size: 1.1rem;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }

  .description {
    max-width: 600px;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    font-size: 1.05rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeIn 0.5s ease forwards 3s;
  }

  .btn {
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: var(--accent);
    color: white;
    box-shadow: 0 4px 15px var(--accent-soft);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px var(--accent-glow);
  }

  .btn-secondary {
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    background: var(--surface-hover);
  }

  @media (max-width: 640px) {
    .name { font-size: 1.75rem; }
    .terminal-body { padding: 1.5rem; }
    .hero-actions { flex-direction: column; }
    .btn { width: 100%; justify-content: center; }
  }
</style>
