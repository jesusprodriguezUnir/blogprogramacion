---
const base = (import.meta as any).env.BASE_URL || '/';
---
<section class="hero">
  <div class="hero-profile">
    <div class="profile-photo-wrap">
      <img src={`${base}assets/profile.jpg`} alt="Foto de Jesús P." class="profile-photo" onerror="this.src='https://api.dicebear.com/7.x/initials/svg?seed=JP&backgroundColor=3b82f6&textColor=ffffff'" />
    </div>
    <h1 class="hero-name">Jesús P.</h1>
    <p class="hero-role">Desarrollador &amp; Entusiasta IA</p>
    <p class="hero-description">
      Apasionado por la programación, la inteligencia artificial y la divulgación tecnológica.
      Comparto noticias, recursos y reflexiones para la comunidad dev en español.
    </p>
    <div class="hero-socials">
      <a href="https://blogpersonal-eta.vercel.app/" class="social-link" target="_blank" rel="noopener" aria-label="Blog personal">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
      </a>
      <a href="https://github.com/jesusprodriguezUnir" class="social-link" target="_blank" rel="noopener" aria-label="GitHub">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
      <a href="https://linkedin.com/" class="social-link" target="_blank" rel="noopener" aria-label="LinkedIn">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
    </div>
  </div>

  <div class="hero-right">
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-number">200+</span>
        <span class="stat-label">Artículos</span>
      </div>
      <div class="stat">
        <span class="stat-number">5k+</span>
        <span class="stat-label">Lectores</span>
      </div>
      <div class="stat">
        <span class="stat-number">100+</span>
        <span class="stat-label">Recursos</span>
      </div>
    </div>
    <div class="hero-topics">
      <span class="topic-tag tag-blue">IA</span>
      <span class="topic-tag tag-green">Web Dev</span>
      <span class="topic-tag tag-purple">Open Source</span>
      <span class="topic-tag tag-blue">Astro</span>
      <span class="topic-tag tag-green">.NET</span>
      <span class="topic-tag tag-purple">Python</span>
    </div>
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
    margin-bottom: 80px;
    padding: 48px 0;
  }

  .hero-profile {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }

  .profile-photo-wrap {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--color-accent-light);
    box-shadow: 0 0 0 6px var(--color-surface-2);
    flex-shrink: 0;
  }

  .profile-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-name {
    font-size: 40px;
    font-weight: 800;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.1;
  }

  .hero-role {
    font-size: 18px;
    font-weight: 600;
    color: var(--color-accent);
    margin: 0;
  }

  .hero-description {
    font-size: 16px;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0;
    max-width: 420px;
  }

  .hero-socials {
    display: flex;
    gap: 12px;
    margin-top: 4px;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--color-surface-2);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: background 0.2s, color 0.2s, transform 0.2s;
    border: 1px solid var(--color-border-subtle);
  }

  .social-link:hover {
    background: var(--color-accent);
    color: #ffffff;
    transform: translateY(-2px);
  }

  .hero-right {
    display: flex;
    flex-direction: column;
    gap: 40px;
    align-items: flex-start;
  }

  .hero-stats {
    display: flex;
    gap: 32px;
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: 20px;
    padding: 32px 40px;
    box-shadow: 0 4px 20px var(--color-shadow);
    width: 100%;
    box-sizing: border-box;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .stat {
    text-align: center;
    flex: 1;
  }

  .stat-number {
    display: block;
    font-size: 32px;
    font-weight: 800;
    color: var(--color-accent);
    margin-bottom: 4px;
  }

  .stat-label {
    font-size: 13px;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .hero-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .topic-tag {
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.3px;
  }

  .tag-blue   { background: rgba(96, 165, 250, 0.15); color: var(--color-accent); }
  .tag-green  { background: rgba(52, 211, 153, 0.15); color: var(--color-accent-green); }
  .tag-purple { background: rgba(167, 139, 250, 0.15); color: var(--color-accent-purple); }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 40px;
      text-align: center;
      padding: 32px 0;
      margin-bottom: 48px;
    }

    .hero-profile {
      align-items: center;
    }

    .hero-description {
      max-width: 100%;
    }

    .hero-socials {
      justify-content: center;
    }

    .hero-right {
      align-items: center;
      width: 100%;
    }

    .hero-stats {
      justify-content: center;
      padding: 24px;
      gap: 24px;
    }

    .hero-topics {
      justify-content: center;
    }

    .hero-name { font-size: 32px; }
  }
</style>
