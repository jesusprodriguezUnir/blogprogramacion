---
import '../styles/global.css';

const base = (import.meta as any).env.BASE_URL || '/';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Mi rincón sobre programación y tecnología" } = Astro.props;
const pathname = Astro.url.pathname;
const currentPath = pathname.replace(base, "") || "";
const canonicalUrl = Astro.url.href;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=Lora:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="prefetch" href={base} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline>
const theme = (() => {
        const saved = localStorage.getItem('theme');
        if (saved) return saved;
        if (window.matchMedia('(prefers-color-scheme: light)').matches) {
          return 'light';
        }
        return 'dark';
      })();
      document.documentElement.setAttribute('data-theme', theme);
    </script>
  </head>
  <body>
    <header class="site-header glass">
      <nav class="nav">
        <a class="brand mono" href={base}>
          <span class="prompt-mark">>_</span> JPRC<span class="cursor">_</span>
        </a>
        <div class="nav-links">
          <a href={base} class={currentPath === "" ? "active" : ""}>~/home</a>
          <a href={`${base}enlaces`} class={currentPath.startsWith("enlaces") ? "active" : ""}>/recursos</a>
          <a href={`${base}prompts`} class={currentPath.startsWith("prompts") ? "active" : ""}>/skills</a>
          <a href={`${base}sobre-mi`} class={currentPath.startsWith("sobre-mi") ? "active" : ""}>/about</a>
        </div>
        <button id="theme-toggle" class="theme-toggle" aria-label="Cambiar tema">
          <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="4.22" x2="19.78" y2="5.64"></line>
          </svg>
          <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>
      </nav>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner container">
        <div class="footer-copy mono">
          <span class="prompt-mark">>_</span> {new Date().getFullYear()} JPRC <span class="separator">::</span> <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener">CC BY 4.0</a>
        </div>
        <div class="footer-socials">
          <a href="https://github.com/jesusprodriguezUnir" aria-label="GitHub" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
        </div>
      </div>
    </footer>

    <script is:inline>
      const themeToggle = document.getElementById('theme-toggle');
      if (themeToggle) {
        themeToggle.addEventListener('click', () => {
          const currentTheme = document.documentElement.getAttribute('data-theme');
          const nextTheme = currentTheme === 'light' ? 'dark' : 'light';
          document.documentElement.setAttribute('data-theme', nextTheme);
          localStorage.setItem('theme', nextTheme);
        });
      }
    </script>
    <script is:inline>
      document.querySelectorAll('a[href^="/blogprogramacion/"], a[href^="/"]').forEach(link => {
        link.addEventListener('mouseenter', () => {
          const url = link.getAttribute('href');
          if (url && url !== window.location.href) {
            const prefetch = document.createElement('link');
            prefetch.rel = 'prefetch';
            prefetch.href = url;
            document.head.appendChild(prefetch);
          }
        });
      });
    </script>
  </body>
</html>

<style is:global>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid var(--border);
    border-radius: 0;
    margin-top: 0;
    background: color-mix(in srgb, var(--bg) 92%, transparent) !important;
    backdrop-filter: blur(7px);
  }

  .nav {
    max-width: 980px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 58px;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .brand {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    letter-spacing: 0.01em;
  }

  .prompt-mark {
    color: var(--accent);
    font-weight: 700;
  }

  .cursor {
    animation: blink 1.1s infinite;
    color: var(--accent);
    font-weight: 400;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .nav-links {
    display: flex;
    gap: 1.2rem;
    margin-left: 1.2rem;
  }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text-muted);
    font-weight: 500;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--accent);
  }

  .theme-toggle {
    margin-left: auto;
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 7px;
    cursor: pointer;
    color: var(--text-muted);
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s var(--ease);
  }

  .theme-toggle:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--surface-hover);
  }

  .icon-sun { display: block; }
  .icon-moon { display: none; }
  [data-theme="dark"] .icon-sun { display: none; }
  [data-theme="dark"] .icon-moon { display: block; }

  .site-footer {
    border-top: 1px solid var(--border);
    padding: 3rem 0;
    margin-top: 5rem;
    background: linear-gradient(to bottom, transparent, var(--bg-soft));
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--text-dim);
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-family: var(--font-mono);
  }

  .footer-copy {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-socials a {
    color: var(--text-muted);
  }

  .footer-socials a:hover {
    color: var(--accent);
  }

  .separator {
    color: var(--border);
  }

  /* Markdown / Content Styles */
  main h1 { font-size: 2.5rem; margin: 2rem 0 1.2rem; color: var(--text); line-height: 1.14; letter-spacing: -0.02em; font-family: var(--font-ui); }
  main h2 { font-size: 1.75rem; margin: 2.2rem 0 0.8rem; color: var(--text); border-bottom: 1px solid var(--border); padding-bottom: 0.45rem; font-family: var(--font-ui); }
  main h3 { font-size: 1.3rem; margin: 1.8rem 0 0.75rem; color: var(--accent); font-family: var(--font-ui); }
  main p { margin-bottom: 1.2rem; line-height: 1.8; color: var(--text-muted); font-size: 1.05rem; max-width: 72ch; }
  main ul, main ol { margin-bottom: 1.2rem; padding-left: 1.5rem; color: var(--text-muted); max-width: 72ch; }
  main li { margin-bottom: 0.45rem; }

  main blockquote {
    margin: 1.8rem 0;
    padding: 1rem 1.3rem;
    background: var(--surface);
    border-left: 3px solid var(--accent);
    color: var(--text);
    border-radius: 0 10px 10px 0;
  }

  main code {
    font-family: var(--font-mono);
    background: var(--surface-hover);
    padding: 0.15rem 0.38rem;
    border-radius: 4px;
    font-size: 0.87em;
    color: var(--accent);
  }

  main pre {
    background: var(--surface-hover) !important;
    padding: 1.15rem;
    border-radius: 12px;
    border: 1px solid var(--border);
    overflow-x: auto;
    margin: 1.5rem 0;
    max-width: 100%;
  }

  main pre code {
    background: transparent;
    padding: 0;
    color: var(--text);
  }

  main strong { color: var(--text); font-weight: 600; font-family: var(--font-ui); }
  main a { color: var(--accent); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px; }
  main a:hover { color: var(--text); }

  @media (max-width: 760px) {
    .nav {
      height: auto;
      padding: 0.65rem 1rem;
      flex-wrap: wrap;
      row-gap: 0.65rem;
    }

    .nav-links {
      order: 3;
      width: 100%;
      margin-left: 0;
      gap: 0.9rem;
      overflow-x: auto;
      white-space: nowrap;
      padding-bottom: 0.2rem;
    }
  }
</style>
