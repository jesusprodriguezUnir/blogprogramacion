---
const base = (import.meta as any).env.BASE_URL || '/';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Mi rincón sobre programación y tecnología" } = Astro.props;
const pathname = Astro.url.pathname;
const currentPath = pathname.replace(base, "") || "";
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      document.documentElement.setAttribute('data-theme', theme);
    </script>
  </head>
  <body>
    <header class="site-header">
      <nav class="nav">
        <a class="brand" href={base}>devIA</a>
        <div class="nav-links">
          <a href={base} class={currentPath === "" ? "active" : ""}>Home</a>
          <a href={`${base}enlaces`} class={currentPath.startsWith("enlaces") ? "active" : ""}>Recursos</a>
          <a href={`${base}prompts`} class={currentPath.startsWith("prompts") ? "active" : ""}>Skills</a>
          <a href={`${base}sobre-mi`} class={currentPath.startsWith("sobre-mi") ? "active" : ""}>Sobre mí</a>
        </div>
        <button id="theme-toggle" class="theme-toggle" aria-label="Cambiar tema">
          <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="4.22" x2="19.78" y2="5.64"></line>
          </svg>
          <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>
      </nav>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-copy">
          © {new Date().getFullYear()} Jesús P. <span class="separator">|</span> <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener">CC BY 4.0 License</a>
        </div>
        <div class="footer-socials">
          <a href="https://github.com/jesusprodriguezUnir" aria-label="GitHub" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
          <a href="https://linkedin.com/" aria-label="LinkedIn" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>
    </footer>

    <script is:inline>
      const themeToggle = document.getElementById('theme-toggle');
      themeToggle.addEventListener('click', () => {
        const currentTheme = document.documentElement.getAttribute('data-theme');
        const nextTheme = currentTheme === 'light' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', nextTheme);
        localStorage.setItem('theme', nextTheme);
      });
    </script>
  </body>
</html>

<style is:global>
  /* ── Design tokens ─────────────────────────────────── */
  :root {
    --bg:           #e8edf4;
    --bg-subtle:    #dfe5ee;
    --surface:      #f0f3f8;
    --surface-2:    #d8dee8;
    --border:       #c8d0dc;
    --border-faint: #d8dee8;
    --text:         #1a2332;
    --text-2:       #4a5568;
    --text-3:       #718096;
    --accent:       #4a90d9;
    --accent-2:     #3182ce;
    --accent-green: #38a169;
    --accent-purple:#805ad5;
    --badge-bg:     #e2e8f0;
    --badge-text:   #2b6cb0;
    --shadow-sm:    0 1px 3px rgba(0,0,0,.05), 0 1px 2px rgba(0,0,0,.03);
    --shadow-md:    0 4px 12px rgba(0,0,0,.05);
    --radius:       8px;
    --radius-lg:    12px;
  }

  [data-theme="dark"] {
    --bg:           #0a1628;
    --bg-subtle:    #0f1d32;
    --surface:      #132240;
    --surface-2:    #1a2d4d;
    --border:       #1e3a5f;
    --border-faint: #1a2d4d;
    --text:         #c8d6e5;
    --text-2:       #8a9bb2;
    --text-3:       #64748b;
    --accent:       #4a9eff;
    --accent-2:     #63b3ed;
    --accent-green: #48bb78;
    --accent-purple:#9f7aea;
    --badge-bg:     #1a2d4d;
    --badge-text:   #63b3ed;
    --shadow-sm:    0 1px 3px rgba(0,0,0,.3);
    --shadow-md:    0 4px 12px rgba(0,0,0,.4);
  }

  /* ── Compatibility aliases (legacy --color-* vars) ─── */
  :root {
    --color-bg:                  var(--bg);
    --color-surface:             var(--surface);
    --color-surface-2:           var(--surface-2);
    --color-border:              var(--border);
    --color-border-subtle:       var(--border-faint);
    --color-text-primary:        var(--text);
    --color-text-secondary:      var(--text-2);
    --color-text-tertiary:       var(--text-3);
    --color-accent:              var(--accent);
    --color-accent-light:        var(--accent-2);
    --color-accent-green:        var(--accent-green);
    --color-accent-purple:       var(--accent-purple);
    --color-shadow:              var(--shadow-sm);
    --color-bg-alt:              var(--bg-subtle);
    --color-link-type-bg:        var(--badge-bg);
    --color-link-type-text:      var(--badge-text);
    --color-text-nav:            var(--text-2);
  }

  /* ── Base ──────────────────────────────────────────── */
  * { box-sizing: border-box; }

  html, body {
    margin: 0;
    padding: 0;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    font-size: 16px;
    line-height: 1.6;
    background: var(--bg);
    color: var(--text);
    -webkit-font-smoothing: antialiased;
    transition: background-color .25s, color .25s;
  }
  
  h1, h2, h3, h4, h5, h6 {
    font-family: 'IBM Plex Mono', monospace;
  }

  /* ── Navigation ────────────────────────────────────── */
  .site-header {
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 24px;
    height: 56px;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .brand {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
    letter-spacing: -0.5px;
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    gap: 16px;
    flex-grow: 1;
    margin-left: 16px;
  }

  .nav-links a {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-2);
    text-decoration: none;
    padding: 6px 4px;
    transition: color .15s;
    position: relative;
  }

  .nav-links a:hover, .nav-links a.active {
    color: var(--accent);
  }
  
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--accent);
    transform: scaleX(0);
    transition: transform .2s ease;
  }

  .nav-links a:hover::after, .nav-links a.active::after {
    transform: scaleX(1);
  }

  .theme-toggle {
    margin-left: auto;
    background: none;
    border: none;
    padding: 8px;
    cursor: pointer;
    color: var(--text-2);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background .15s, color .15s;
  }

  .theme-toggle:hover {
    background: var(--surface-2);
    color: var(--text);
  }

  .icon-sun { display: block; }
  .icon-moon { display: none; }
  [data-theme="dark"] .icon-sun { display: none; }
  [data-theme="dark"] .icon-moon { display: block; }

  /* ── Main container ────────────────────────────────── */
  .container {
    max-width: 860px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  /* ── Footer ────────────────────────────────────────── */
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 40px 0;
    margin-top: auto;
  }

  .footer-inner {
    max-width: 860px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    font-size: 14px;
    color: var(--text-3);
  }

  .footer-copy {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .footer-copy a {
    color: var(--text-3);
    text-decoration: none;
    transition: color .2s;
  }

  .footer-copy a:hover {
    color: var(--accent);
  }
  
  .separator {
    opacity: 0.5;
  }

  .footer-socials {
    display: flex;
    gap: 20px;
  }

  .footer-socials a {
    color: var(--text-3);
    transition: color .2s;
  }

  .footer-socials a:hover {
    color: var(--accent);
  }

  /* ── Prose (blog posts) ────────────────────────────── */
  .prose {
    max-width: 680px;
    margin: 0 auto;
  }

  .prose h1 { font-size: 2.25rem; margin-bottom: 1rem; color: var(--text); }
  .prose h2 { font-size: 1.5rem; margin-top: 2rem; margin-bottom: 0.75rem; color: var(--text); }
  .prose p { margin-bottom: 1.25rem; color: var(--text-2); line-height: 1.7; }
</style>
